# Copy this file to .env and fill in your values
# Football-Data.org API key (free tier)
# Register at https://www.football-data.org/documentation/quickstart
FOOTBALL_DATA_API_KEY=your_key_here

# Django secret key (override in production)
# DJANGO_SECRET_KEY=

# Production database URL (leave blank for local SQLite)
# DATABASE_URL=

# Better Stack (Logtail) logging — both required for logs to be ingested.
# Find them in Better Stack: Sources > your source > Connect.
# In production set these as Railway service variables, not in this file.
# LOGTAIL_SOURCE_TOKEN=
# LOGTAIL_INGESTING_HOST=s1234567.eu-nbg-2.betterstackdata.com

# Optional: override the default log level (INFO)
# DJANGO_LOG_LEVEL=INFO
